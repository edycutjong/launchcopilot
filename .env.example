# ── Anthropic (Claude) ───────────────────────────────────────
# Powers the launch-kit pipeline (profile synthesis, generators, persona panel).
# Get from: https://console.anthropic.com/settings/keys
# NOT required to run the ASO grader, the /api/analyze endpoint, or the CLI.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Demo mode ─────────────────────────────────────────────────
# Set to 1 to replay a recorded launch kit instead of calling Claude —
# lets judges run the full flow locally with no API key.
DEMO_MODE=1

# ── Rate limiting ─────────────────────────────────────────────
# Free-tier kits per day per IP (in-memory; resets on redeploy).
FREE_KITS_PER_DAY=3

# ── Optional: shared kits + waitlist (Vercel KV / Upstash) ────
# Get from: https://vercel.com/dashboard → Storage → KV. App runs without these.
# KV_REST_API_URL=https://your-kv.upstash.io
# KV_REST_API_TOKEN=your-token-here
